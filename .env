# Host GPU device-node group GIDs (this dev laptop). Regenerate per host:
#   echo "RENDER_GID=$(getent group render | cut -d: -f3)"  > .env
#   echo "VIDEO_GID=$(getent group video | cut -d: -f3)"    >> .env
RENDER_GID=989
VIDEO_GID=985

# Unsupported GPUs (e.g. the Radeon 780M / gfx1103 iGPU) need an HSA override to
# masquerade as a supported arch. Officially-supported cards (e.g. RX 7900) do NOT
# — leave it unset. If you need it, don't edit this committed file: put it in a
# local, gitignored docker-compose.override.yml (see README), e.g.:
#   services: {kokoro-tts: {environment: {HSA_OVERRIDE_GFX_VERSION: "11.0.0"}}}

# Default voice (American English female). List all with GET /voices. The first
# letter of the voice picks the language: a = American, b = British English.
KOKORO_VOICE=af_heart

# MIOPEN_FIND_MODE=2 avoids the broken conv-benchmark timing on gfx1103.
MIOPEN_FIND_MODE=2
